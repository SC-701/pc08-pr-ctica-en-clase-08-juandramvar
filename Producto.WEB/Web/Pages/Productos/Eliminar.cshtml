@page
@model Web.Pages.Productos.EliminarModel

@{
    ViewData["Title"] = "Eliminar producto";
}

<h1>Eliminar producto</h1>

@if (!string.IsNullOrEmpty(Model.MensajeError))
{
    <div class="alert alert-danger">
        @Model.MensajeError
    </div>
}
else
{
    <div class="alert alert-warning">
        ¿Seguro que deseas eliminar este producto?
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>Id:</strong> @Model.Producto.Id</p>
            <p><strong>Nombre:</strong> @Model.Producto.Nombre</p>
            <p><strong>Descripción:</strong> @Model.Producto.Descripcion</p>
            <p><strong>Precio:</strong> @Model.Producto.Precio</p>
            <p><strong>Stock:</strong> @Model.Producto.Stock</p>
            <p><strong>Código de barras:</strong> @Model.Producto.CodigoBarras</p>
            <p><strong>Subcategoría:</strong> @Model.Producto.SubCategoria</p>
            <p><strong>Categoría:</strong> @Model.Producto.Categoria</p>
            <p><strong>Precio USD:</strong> @Model.Producto.PrecioUSD</p>
        </div>
    </div>

    <form method="post" class="mt-3">
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-page="/Productos/Index" class="btn btn-secondary">Cancelar</a>
    </form>
}