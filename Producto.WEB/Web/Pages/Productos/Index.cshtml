@page
@model Web.Pages.Productos.IndexModel

@{
    ViewData["Title"] = "Lista de productos";
}

<h1>Lista de productos</h1>

@if (!string.IsNullOrEmpty(Model.MensajeError))
{
    <div class="alert alert-danger">
        @Model.MensajeError
    </div>
}
<p>
    <a asp-page="/Productos/Agregar" class="btn btn-primary">Agregar producto</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Código de barras</th>
            <th>Subcategoría</th>
            <th>Categoría</th>
            <th>Precio USD</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Productos != null && Model.Productos.Any())
        {
            @foreach (var producto in Model.Productos)
            {
                <tr>
                    <td>@producto.Id</td>
                    <td>@producto.Nombre</td>
                    <td>@producto.Descripcion</td>
                    <td>@producto.Precio</td>
                    <td>@producto.Stock</td>
                    <td>@producto.CodigoBarras</td>
                    <td>@producto.SubCategoria</td>
                    <td>@producto.Categoria</td>
                    <td>@producto.PrecioUSD</td>
                    <td>
                        <a asp-page="/Productos/Detalle" asp-route-id="@producto.Id">Detalle</a> |
                        <a asp-page="/Productos/Editar" asp-route-id="@producto.Id">Editar</a> |
                        <a asp-page="/Productos/Eliminar" asp-route-id="@producto.Id">Eliminar</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="10">No hay productos para mostrar.</td>
            </tr>
        }
    </tbody>
</table>